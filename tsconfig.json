{
	"compilerOptions": {
		// Target latest version of ECMAScript.
		"target": "esnext",
		// Explicit module target — vue-tsc prefers explicit over inferred.
		"module": "esnext",
		// Search under node_modules for non-relative imports.
		"moduleResolution": "node",
		// Process & infer types from .js files.
		"allowJs": true,
		// Don't emit; allow Babel to transform files.
		"noEmit": true,
		// Enable strictest settings like strictNullChecks & noImplicitAny.
		"strict": true,
		// Disallow features that require cross-file information for emit.
		"isolatedModules": true,
		// Import non-ES modules as default imports.
		"esModuleInterop": true,
		// enable json modules import
		"resolveJsonModule": true,
		// Ambient globals: @types/node for Node built-ins; vitest/globals for
		// describe/test/expect in .test.ts files (vitest.config.mjs sets globals: true).
		"types": ["node", "vitest/globals"],
		// Skip type-checking of declaration files in node_modules; third-party
		// .d.ts subpath-import quirks (vite, @vitest/utils) are not our concern.
		"skipLibCheck": true,
		// Harmless without JSX; future-proofs vue-tsc integration if any SFC
		// template introduces JSX-style expressions.
		"jsx": "preserve"
	},
	"include": ["src/**/*"]
}
