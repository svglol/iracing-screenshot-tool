# ── Discord ──────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications → Bot tab
DISCORD_TOKEN=
# Application ID (same page as token, top of General Information)
DISCORD_CLIENT_ID=
# Guild ID for dev — commands register instantly. Leave EMPTY in prod for global registration.
DISCORD_GUILD_ID=
# Channel ID where bug/feature posts land (public, per D-02)
DISCORD_REPORTS_CHANNEL_ID=
# Role ID granted triage permissions (per D-15 "Maintainer" role)
DISCORD_MAINTAINER_ROLE_ID=
# Owner Discord user ID — hard-coded triage bypass (per D-15)
DISCORD_OWNER_ID=

# ── GitHub ───────────────────────────────────────────────────────────
# Fine-grained PAT scoped to this repo with Issues:read/write and Contents:read/write (D-09, D-18)
GITHUB_TOKEN=
GITHUB_OWNER=svglol
GITHUB_REPO=iracing-screenshot-tool
# Branch used exclusively for re-hosted attachments (orphan branch, per D-18)
GITHUB_ATTACHMENTS_BRANCH=bug-attachments

# ── Webhook receiver ─────────────────────────────────────────────────
# Shared secret configured in GitHub repo Settings → Webhooks (D-13)
GITHUB_WEBHOOK_SECRET=
# Port Fastify listens on; Cloudflare Tunnel maps this locally (D-19)
WEBHOOK_PORT=3001

# ── Rate limiting (D-14) ─────────────────────────────────────────────
# Per-user daily cap on /bug + /feature submissions
RATE_LIMIT_PER_DAY=3

# ── Logging ──────────────────────────────────────────────────────────
# Set to 'debug' to include DEBUG lines, otherwise INFO only
LOG_LEVEL=info
# Override log directory; defaults to ./logs
LOG_DIR=

# ── Node env ─────────────────────────────────────────────────────────
NODE_ENV=production
