{
    "name": "iracing-screenshot-tool",
    "productName": "iRacing Screenshot Tool",
    "version": "2.1.0",
    "description": "A tool for taking high resolution screenshots in iRacing",
    "repository": "svglol/iracing-screenshot-tool",
    "author": {
        "name": "Matthew",
        "email": "savageguy@gmail.com",
        "url": "github.com/svglol"
    },
    "build": {
        "appId": "com.svglol.iracing-screenshot-tool",
        "productName": "iRacing Screenshot Tool",
        "directories": {
            "output": "./build/"
        },
        "files": [
            "package.json",
            "dist/**/*",
            "node_modules/**/*",
            "static/icon.*",
            "!bot/**/*"
        ],
        "extraResources": [
            {
                "from": "static/icon.png",
                "to": "icon.png"
            }
        ],
        "win": {
            "icon": "static/icon.png",
            "target": [
                "nsis",
                "portable"
            ],
            "signAndEditExecutable": false
        },
        "nsis": {
            "include": "_scripts/installer.nsh"
        },
        "electronDist": "node_modules/electron/dist"
    },
    "main": "./dist/main.js",
    "dependencies": {
        "@electron/remote": "^2.1.3",
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-brands-svg-icons": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@fortawesome/vue-fontawesome": "^3.2.0",
        "@oruga-ui/oruga-next": "^0.13.4",
        "@oruga-ui/theme-bulma": "^0.9.0",
        "bulma": "^1.0.4",
        "electron-store": "^5.1.1",
        "electron-updater": "^6.8.3",
        "image-size": "^0.8.3",
        "irsdk-node": "^4.4.0",
        "read-ini-file": "^3.0.0",
        "sharp": "^0.34.5",
        "vue": "^3.5.33",
        "vue-lazyload": "^3.0.0",
        "vue-router": "^4.5.0",
        "vue-simple-context-menu": "^4.1.0",
        "vue3-markdown-it": "^1.0.10",
        "vue3-shortkey": "^4.0.0"
    },
    "devDependencies": {
        "@babel/core": "^7.9.0",
        "@babel/eslint-parser": "^7.28.6",
        "@babel/plugin-proposal-class-properties": "^7.8.3",
        "@babel/plugin-proposal-object-rest-spread": "^7.9.0",
        "@babel/preset-env": "^7.9.0",
        "@babel/preset-typescript": "^7.9.0",
        "@electron/rebuild": "^4.0.3",
        "@eslint/compat": "^2.0.5",
        "@eslint/eslintrc": "^3.3.5",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/devtools": "^8.1.1",
        "deepmerge": "^4.2.2",
        "electron": "^41.2.1",
        "electron-builder": "^26.8.1",
        "electron-debug": "^3.0.1",
        "electron-vite": "^5.0.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-config-standard": "^14.1.1",
        "eslint-plugin-import": "^2.22.1",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-prettier": "^5.2.1",
        "eslint-plugin-promise": "^4.2.1",
        "eslint-plugin-standard": "^4.0.1",
        "eslint-plugin-vue": "^9.33.0",
        "fast-glob": "^3.2.2",
        "globals": "^15.15.0",
        "jest": "^30.3.0",
        "jimp": "^1.6.1",
        "np": "^11.2.0",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.3.3",
        "sass": "^1.26.3",
        "typescript": "~5.7.3",
        "typescript-eslint": "^8.59.0",
        "vue-eslint-parser": "^7.0.0"
    },
    "scripts": {
        "build": "run-s rebuild:electron pack build:dir",
        "build:dev": "run-s rebuild:electron pack build:dev:dir",
        "build:dev:dir": "node _scripts/build-dev.js --dir",
        "build-publish": "run-s rebuild:electron pack && electron-builder --publish always",
        "debug": "run-s rebuild:electron debug-runner",
        "debug-runner": "node _scripts/dev-runner.js --remote-debug",
        "dev": "run-s rebuild:electron dev-runner",
        "dev-runner": "node _scripts/dev-runner.js",
        "electron-builder-install": "electron-builder install-app-deps",
        "electron-rebuild": "electron-rebuild -f --which-module irsdk-node,sharp",
        "jest": "jest",
        "jest:coverage": "jest --collect-coverage",
        "jest:watch": "jest --watch",
        "lint": "eslint --fix ./",
        "pack": "run-p pack:main pack:renderer",
        "pack:main": "webpack --mode=production --config _scripts/webpack.main.config.js",
        "pack:renderer": "webpack --mode=production --config _scripts/webpack.renderer.config.js",
        "postinstall": "run-s electron-builder-install electron-rebuild",
        "prettier": "prettier --write \"{src,_scripts}/**/*.{js,ts,vue}\"",
        "rebuild:electron": "run-s electron-builder-install electron-rebuild",
        "rebuild:node": "npm rebuild",
        "test": "jest --passWithNoTests",
        "test:watch": "run-s rebuild:node jest:watch --passWithNoTests",
        "type-check": "tsc --noEmit",
        "build:dir": "electron-builder --dir",
        "build:installer": "run-s rebuild:electron pack && electron-builder",
        "release": "node _scripts/release.js"
    },
    "jest": {
        "testPathIgnorePatterns": [
            "/node_modules/",
            "/.tools/",
            "/dist/",
            "/build/",
            "/bot/"
        ]
    }
}
